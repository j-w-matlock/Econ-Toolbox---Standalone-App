<UserControl x:Class="EconToolbox.Desktop.Views.StageDamageOrganizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EconToolbox.Desktop.Views.Controls"
             Background="{DynamicResource App.SurfaceAlt}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <ScrollViewer Style="{StaticResource ScrollViewer.Page}">
        <Grid Style="{StaticResource Layout.ContentGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource Border.Explainer}">
                <StackPanel>
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text=""
                                   Style="{StaticResource Text.Icon.Section}"/>
                        <TextBlock Grid.Column="1"
                                   Text="Stage Damage CSV Organizer"
                                   Style="{StaticResource Text.SectionTitleAccent}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap"
                               Style="{StaticResource Text.Body}"
                               Margin="{StaticResource Margin.TopLarge}">
                        Upload Stage Damage Functions_StructureStageDamageDetails.csv exports from FDA 2.0. The organizer groups results by <Run FontStyle="Italic">DamageCategory</Run>, surfaces structures with the highest AEP structure damages, and builds a stacked bar chart for quick review.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  Margin="{StaticResource Margin.TopSection}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Margin="{StaticResource Margin.InlineLarge}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                    <Border Style="{StaticResource Border.Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Grid.Column="0"
                                        Margin="{StaticResource Margin.InlineLarge}">
                                <Button Command="{Binding ImportCsvCommand}"
                                        Style="{StaticResource Button.Action}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="" Style="{StaticResource Text.Icon.Action}"/>
                                        <TextBlock Text="Upload CSVs"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ClearCommand}"
                                        Style="{StaticResource Button.Action}"
                                        Margin="8,0,0,0"
                                        IsEnabled="{Binding HasRecords}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="" Style="{StaticResource Text.Icon.Action}"/>
                                        <TextBlock Text="Clear"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="{StaticResource Margin.InlineLarge}">
                                <TextBlock Text="Summary names (one per uploaded file)"
                                           Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding Summaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2,0,0">
                                                <TextBlock Text="{Binding SourceLabel}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"/>
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Form.TextBox}"
                                                         Margin="0,4,0,0"
                                                         ToolTip="Edit the summary name for this file. Used for chart legends and CSV output. The label does not change calculations but affects how results are identified."/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,8,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Impact Area filter:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ComboBox Width="220"
                                              ItemsSource="{Binding ImpactAreaOptions}"
                                              SelectedItem="{Binding SelectedImpactArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Button Command="{Binding SaveSummaryCommand}"
                                        Style="{StaticResource Button.Action}"
                                        IsEnabled="{Binding HasRecords}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="" Style="{StaticResource Text.Icon.Action}"/>
                                        <TextBlock Text="Save Summary"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SavePivotTableCommand}"
                                        Style="{StaticResource Button.Action}"
                                        Margin="0,8,0,0"
                                        IsEnabled="{Binding HasRecords}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="" Style="{StaticResource Text.Icon.Action}"/>
                                        <TextBlock Text="Save as Pivot Table"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding StatusMessage}"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource App.TextSecondary}"
                                   Margin="4,0,0,4"/>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Margin="{StaticResource Margin.CardGap}">
                                <Border Style="{StaticResource Border.Card}"
                                        Margin="{StaticResource Margin.CardGap}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Structure count by AEP"
                                                   Style="{StaticResource Text.SectionTitle}"
                                                   Margin="0,0,0,8"/>
                                        <DataGrid CanUserResizeColumns="True" x:Name="StructureCountByAepSummaryGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding StructureCountByAepSummaries}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  ColumnWidth="Auto"
                                                  MinHeight="140"
                                                  MaxHeight="240"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource Border.Card}"
                                        Margin="{StaticResource Margin.CardGap}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Structure DamageCategory summary"
                                                   Style="{StaticResource Text.SectionTitle}"
                                                   Margin="0,0,0,8"/>
                                        <DataGrid CanUserResizeColumns="True" x:Name="CategorySummaryGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding CategorySummaries}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  ColumnWidth="Auto"
                                                  MinHeight="160"
                                                  MaxHeight="260"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource Border.Card}"
                                        Margin="{StaticResource Margin.CardGap}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Content DamageCategory summary"
                                                   Style="{StaticResource Text.SectionTitle}"
                                                   Margin="0,0,0,8"/>
                                        <DataGrid CanUserResizeColumns="True" x:Name="ContentCategorySummaryGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding ContentCategorySummaries}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  ColumnWidth="Auto"
                                                  MinHeight="160"
                                                  MaxHeight="260"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource Border.Card}"
                                        Margin="{StaticResource Margin.CardGap}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Other DamageCategory summary"
                                                   Style="{StaticResource Text.SectionTitle}"
                                                   Margin="0,0,0,8"/>
                                        <DataGrid CanUserResizeColumns="True" x:Name="OtherCategorySummaryGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding OtherCategorySummaries}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  ColumnWidth="Auto"
                                                  MinHeight="160"
                                                  MaxHeight="260"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource Border.Card}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Vehicle DamageCategory summary"
                                                   Style="{StaticResource Text.SectionTitle}"
                                                   Margin="0,0,0,8"/>
                                        <DataGrid CanUserResizeColumns="True" x:Name="VehicleCategorySummaryGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding VehicleCategorySummaries}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  ColumnWidth="Auto"
                                                  MinHeight="160"
                                                  MaxHeight="260"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Style="{StaticResource Border.Card}"
                                    Margin="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Top structure damages (highest AEP)"
                                               Style="{StaticResource Text.SectionTitle}"
                                               Margin="0,0,0,8"/>
                                    <DataGrid CanUserResizeColumns="True" Grid.Row="1"
                                              ItemsSource="{Binding Highlights}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              ColumnWidth="Auto"
                                              MinHeight="220"
                                              MaxHeight="360"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Summary Name"
                                                                 Binding="{Binding SummaryName}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Structure FID"
                                                                 Binding="{Binding StructureFid}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Damage Category"
                                                                 Binding="{Binding DamageCategory}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Impact Area"
                                                                 Binding="{Binding ImpactArea}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Description"
                                                                 Binding="{Binding Description}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Highest AEP"
                                                                 Binding="{Binding HighestAepLabel}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Depth Above First Floor"
                                                                 Binding="{Binding DepthAboveFirstFloorAtHighestAep, StringFormat=0.##}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Structure Damage"
                                                                 Binding="{Binding HighestStructureDamage, StringFormat=C0}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="X Coordinate"
                                                                 Binding="{Binding XCoordinate, StringFormat=0.###}"
                                                                 Width="SizeToHeader"/>
                                            <DataGridTextColumn Header="Y Coordinate"
                                                                 Binding="{Binding YCoordinate, StringFormat=0.###}"
                                                                 Width="SizeToHeader"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource Border.Card}"
                                    Margin="{StaticResource Margin.TopSection}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Top structure map explorer (X/Y coordinates)"
                                               Style="{StaticResource Text.SectionTitle}"
                                               Margin="0,0,0,8"/>
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding SelectedMapPointSummary}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource App.TextSecondary}"
                                                       Margin="0,0,8,0"
                                                       DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding MapPointCountSummary}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource App.TextSecondary}"
                                                       FontStyle="Italic"
                                                       DockPanel.Dock="Right"/>
                                        </DockPanel>
                                        <Grid Grid.Row="1" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Command="{Binding ZoomOutMapCommand}"
                                                    Style="{StaticResource Button.Action}">
                                                <TextBlock Text="-" FontWeight="Bold"/>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Command="{Binding ZoomInMapCommand}"
                                                    Style="{StaticResource Button.Action}"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="+" FontWeight="Bold"/>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Command="{Binding ResetMapViewCommand}"
                                                    Style="{StaticResource Button.Action}"
                                                    Margin="8,0,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="" Style="{StaticResource Text.Icon.Action}"/>
                                                    <TextBlock Text="Reset view"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding MapZoomLabel}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <Slider Grid.Column="5"
                                                    Width="200"
                                                    Minimum="0.5"
                                                    Maximum="12"
                                                    TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding MapZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <Border Style="{StaticResource Border.Panel}"
                                                Grid.Row="2"
                                                Padding="{StaticResource Padding.Card}"
                                                Background="{DynamicResource App.SurfaceAlt}"
                                                MinHeight="660">
                                            <ScrollViewer x:Name="MapScrollViewer"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto"
                                                          CanContentScroll="False"
                                                          PreviewMouseLeftButtonDown="MapScrollViewer_OnPreviewMouseLeftButtonDown"
                                                          PreviewMouseLeftButtonUp="MapScrollViewer_OnPreviewMouseLeftButtonUp"
                                                          PreviewMouseMove="MapScrollViewer_OnPreviewMouseMove"
                                                          MouseLeave="MapScrollViewer_OnPreviewMouseLeave"
                                                          PreviewMouseWheel="MapScrollViewer_OnPreviewMouseWheel">
                                                <Grid x:Name="MapSurface"
                                                      Width="{Binding MapCanvasWidth}"
                                                      Height="{Binding MapCanvasHeight}"
                                                      Background="{DynamicResource App.Surface}"
                                                      RenderTransformOrigin="0,0">
                                                    <Grid.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding MapZoom}" ScaleY="{Binding MapZoom}"/>
                                                    </Grid.LayoutTransform>
                                                    <Rectangle Fill="{DynamicResource App.Visualization.MapOverlayFill}"/>
                                                    <Rectangle Stroke="{DynamicResource App.Visualization.MapOverlayBorder}" StrokeThickness="1" Margin="24"/>
                                                    <Canvas>
                                                        <Line X1="24" Y1="24" X2="24" Y2="596" Stroke="{DynamicResource App.Visualization.MapAxis}" StrokeThickness="1"/>
                                                        <Line X1="24" Y1="596" X2="956" Y2="596" Stroke="{DynamicResource App.Visualization.MapAxis}" StrokeThickness="1"/>
                                                        <Line X1="490" Y1="24" X2="490" Y2="596" Stroke="{DynamicResource App.Visualization.MapOverlayBorder}" StrokeThickness="0.7" StrokeDashArray="4,6"/>
                                                        <Line X1="24" Y1="310" X2="956" Y2="310" Stroke="{DynamicResource App.Visualization.MapOverlayBorder}" StrokeThickness="0.7" StrokeDashArray="4,6"/>
                                                        <ListBox ItemsSource="{Binding TopStructureMapPoints}"
                                                                 SelectedItem="{Binding SelectedMapPoint, Mode=TwoWay}"
                                                                 Width="{Binding MapCanvasWidth}"
                                                                 Height="{Binding MapCanvasHeight}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                                 HorizontalContentAlignment="Stretch"
                                                                 VerticalContentAlignment="Stretch">
                                                                <ListBox.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <Canvas />
                                                                    </ItemsPanelTemplate>
                                                                </ListBox.ItemsPanel>
                                                                <ListBox.ItemContainerStyle>
                                                                    <Style TargetType="ListBoxItem">
                                                                        <Setter Property="Canvas.Left" Value="{Binding ScaledX}"/>
                                                                        <Setter Property="Canvas.Top" Value="{Binding ScaledY}"/>
                                                                        <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                                                                        <Setter Property="Padding" Value="0"/>
                                                                        <Setter Property="Margin" Value="0"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="Focusable" Value="False"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                                    <Ellipse Width="10" Height="10"
                                                                                             Fill="{DynamicResource App.Chart.Series1}"
                                                                                             Stroke="{DynamicResource App.Surface}"
                                                                                             StrokeThickness="1.2"/>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                                            <Ellipse Width="14" Height="14"
                                                                                                     Fill="{DynamicResource App.Chart.Series2}"
                                                                                                     Stroke="{DynamicResource App.TextPrimary}"
                                                                                                     StrokeThickness="2"/>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                        <TextBlock Text="{Binding MapExtentTopLeft}"
                                                                   Style="{StaticResource Text.Tooltip}"
                                                                   Foreground="{DynamicResource App.TextSecondary}"
                                                                   Canvas.Left="6"
                                                                   Canvas.Top="4"/>
                                                        <TextBlock Text="{Binding MapExtentBottomRight}"
                                                                   Style="{StaticResource Text.Tooltip}"
                                                                   Foreground="{DynamicResource App.TextSecondary}"
                                                                   Canvas.Left="650"
                                                                   Canvas.Top="600"/>
                                                    </Canvas>
                                                </Grid>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Border Grid.Column="1"
                        Style="{StaticResource Border.Card}"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Total structure damage by damage category"
                                   Style="{StaticResource Text.SectionTitle}"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding LegendItems}"
                                      Margin="{StaticResource Margin.CardGap}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <Ellipse Width="12"
                                                 Height="12"
                                                 Fill="{Binding Color}"
                                                 Stroke="{DynamicResource App.Border}"
                                                 StrokeThickness="0.5"
                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Style="{StaticResource Border.Panel}"
                                Background="{DynamicResource App.ChartFill}"
                                BorderBrush="{DynamicResource App.Border}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.MD}"
                                Padding="{StaticResource Padding.Card}"
                                HorizontalAlignment="Stretch">
                            <controls:BarChartControl Height="420"
                                                      MinHeight="320"
                                                      HorizontalAlignment="Stretch"
                                                      Series="{Binding ChartSeries}"
                                                      EmptyMessage="{Binding StatusMessage}"/>
                        </Border>
                        <TextBlock Text="{Binding FrequentAepLabelSummary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource App.TextSecondary}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
